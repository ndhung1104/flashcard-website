{
  "crons": [
    {
      "path": "/api/import?action=drive-sync-cron",
      "schedule": "*/30 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": "text/html.*"
        }
      ],
      "destination": "/index.html"
    }
  ]
}
